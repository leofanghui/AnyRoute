# OmniRoute minimal environment contract
#
# Copy to .env and adjust values for your local deployment. Only variables used by
# the retained minimal router profile are listed here.

# Required secrets
JWT_SECRET=
API_KEY_SECRET=
INITIAL_PASSWORD=CHANGEME

# Storage
# DATA_DIR=/var/lib/omniroute
STORAGE_ENCRYPTION_KEY=
STORAGE_ENCRYPTION_KEY_VERSION=v1
DISABLE_SQLITE_AUTO_BACKUP=false

# Server
PORT=20128
# API_PORT=20129
# API_HOST=0.0.0.0
# DASHBOARD_PORT=20128
# HOST=0.0.0.0
# HOSTNAME=127.0.0.1
NODE_ENV=production
OMNIROUTE_USE_TURBOPACK=1

# Auth and API keys
REQUIRE_API_KEY=false
# OMNIROUTE_API_KEY=
# ROUTER_API_KEY=
# DEFAULT_RATE_LIMIT_PER_DAY=1000
# AUTH_COOKIE_SECURE=false

# Database health and migrations
# OMNIROUTE_SKIP_DB_HEALTHCHECK=1
# OMNIROUTE_FORCE_DB_HEALTHCHECK=1
# OMNIROUTE_DB_HEALTHCHECK_INTERVAL_MS=300000
# OMNIROUTE_MIGRATIONS_DIR=
# OMNIROUTE_MAX_PENDING_MIGRATIONS=200

# Request/body limits
# MAX_BODY_SIZE_BYTES=52428800
# OMNIROUTE_SERVER_ACTIONS_BODY_LIMIT=50mb
# NEXT_PROXY_BODY_LIMIT=512mb
# OMNIROUTE_DEFAULT_FETCH_TIMEOUT_MS=120000
# FETCH_TIMEOUT_MS=120000

# Redis-backed rate limiting/auth cache
REDIS_URL=redis://localhost:6379
# OMNIROUTE_DISABLE_REDIS_AUTH_CACHE=1

# Provider and model runtime
# MODEL_ALIAS_COMPAT_ENABLED=true
# CLI_COMPAT_ALL=false
# OMNIROUTE_PREFER_CLAUDE_CODE_FOR_UNPREFIXED_CLAUDE_MODELS=false
# ALLOW_MULTI_CONNECTIONS_PER_COMPAT_NODE=false
# CREDENTIAL_HEALTH_CHECK_INTERVAL=300000
# CREDENTIAL_HEALTH_CACHE_TTL=300000
# OMNIROUTE_DISABLE_CREDENTIAL_HEALTH_CHECK=false
# OMNIROUTE_DISABLE_TOKEN_HEALTHCHECK=false
# OMNIROUTE_HEALTHCHECK_SKIP_PROVIDERS=
# MODEL_SYNC_INTERVAL_HOURS=24

# Proxy and network
# HTTP_PROXY=
# HTTPS_PROXY=
# ALL_PROXY=
# NO_PROXY=localhost,127.0.0.1
# ENABLE_SOCKS5_PROXY=false
# ENABLE_TLS_FINGERPRINT=false
# OMNIROUTE_PROXY_FETCH_DEBUG=false
# OMNIROUTE_TLS_PROXY_URL=

# Runtime memory and caches
# OMNIROUTE_MEMORY_MB=512
# HEAP_PRESSURE_THRESHOLD_MB=
# STREAM_HISTORY_MAX=50
# PROMPT_CACHE_MAX_SIZE=50
# PROMPT_CACHE_MAX_BYTES=2097152
# PROMPT_CACHE_TTL_MS=300000
# SEMANTIC_CACHE_MAX_SIZE=100
# SEMANTIC_CACHE_MAX_BYTES=4194304
# SEMANTIC_CACHE_TTL_MS=1800000
# CONTEXT_LENGTH_DEFAULT=128000
# CONTEXT_RESERVE_TOKENS=1024
# USAGE_TOKEN_BUFFER=100

# Pricing and catalogs
# PRICING_SYNC_ENABLED=false
# OPENROUTER_CATALOG_TTL_MS=3600000
# CLOUDFLARE_ACCOUNT_ID=

# Compatibility bridges used by retained /v1 runtime paths
# OMNIROUTE_WS_BRIDGE_SECRET=
# OMNIROUTE_LOG_REQUEST_SHAPE=1
# OMNIROUTE_DISABLE_BACKGROUND_SERVICES=false
# OMNIROUTE_ENABLE_RUNTIME_BACKGROUND_TASKS=0

# Test/E2E
# NEXT_PUBLIC_OMNIROUTE_E2E_MODE=true
# OMNIROUTE_E2E_BOOTSTRAP_MODE=auth
# OMNIROUTE_E2E_PASSWORD=
# OMNIROUTE_DISABLE_LOCAL_HEALTHCHECK=true
